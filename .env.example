# ============================================================================
#  MIRAGE — Environment Variables Template
# ============================================================================
#  Copy this file to `.env` and adjust values for your deployment.
#
#    cp .env.example .env
#
#  Every variable below has a sensible default inside config.py.
#  You only need to set the ones you want to override.
# ============================================================================

# ── Database ────────────────────────────────────────────────────────────────
# Absolute path to the SQLite database file.
# Default: <project_root>/mirage.db
# MIRAGE_DB_PATH=/data/mirage.db

# ── Cowrie Honeypot ─────────────────────────────────────────────────────────
# Path to the Cowrie JSON log file that the ingestion service watches.
# Default: /var/log/cowrie/cowrie.json
# COWRIE_LOG_PATH=/var/log/cowrie/cowrie.json

# ── Dashboard Server ───────────────────────────────────────────────────────
# Host and port the Flask dashboard listens on.
# DASHBOARD_HOST=0.0.0.0
# DASHBOARD_PORT=5000

# Secret key used for Flask session signing and CSRF protection.
# IMPORTANT: Change this to a long random string in production!
# SECRET_KEY=mirage-dashboard-secret

# Auto-refresh interval for the dashboard (seconds).
# DASHBOARD_REFRESH=30

# ── Decoy HTTP Server ──────────────────────────────────────────────────────
# Host and port the HTTP decoy listens on.
# DECOY_HOST=0.0.0.0
# DECOY_PORT=8080

# ── Clustering (DBSCAN) ────────────────────────────────────────────────────
# Maximum distance between two samples to be considered in the same
# neighbourhood (epsilon).
# CLUSTER_EPS=0.5

# Minimum number of samples required to form a cluster core point.
# CLUSTER_MIN_SAMPLES=3

# ── Feature Flags ───────────────────────────────────────────────────────────
# Enable or disable the rule-based bot-detection heuristics.
# ENABLE_BOT_DETECTION=true

# Enable or disable the real-time live-feed websocket endpoint.
# ENABLE_LIVE_FEED=true

# ── HTTP Session Grouping ──────────────────────────────────────────────────
# Requests from the same IP within this window (seconds) are grouped
# into a single logical session.
# HTTP_SESSION_WINDOW=1800
